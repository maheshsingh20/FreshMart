{
  "Jwt": {
    "Secret": "super-secret-jwt-key-change-in-production-min32chars!",
    "Issuer": "GroceryPlatform",
    "Audience": "GroceryPlatformClients"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1m", "Limit": 100 },
      { "Endpoint": "post:/api/v1/auth/login", "Period": "5m", "Limit": 10 },
      { "Endpoint": "post:/api/v1/auth/send-otp", "Period": "5m", "Limit": 5 },
      { "Endpoint": "post:/api/v1/auth/forgot-password", "Period": "5m", "Limit": 5 },
      { "Endpoint": "post:/api/v1/auth/verify-email", "Period": "5m", "Limit": 10 },
      { "Endpoint": "post:/api/v1/auth/reset-password", "Period": "5m", "Limit": 5 }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "products-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/v1/products/{**catch-all}" }
      },
      "categories-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/v1/categories/{**catch-all}" }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/v1/cart/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/v1/orders/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v1/payments/{**catch-all}" }
      },
      "deliveries-route": {
        "ClusterId": "delivery-cluster",
        "Match": { "Path": "/api/v1/deliveries/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/v1/notifications/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "notifications-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      },
      "reviews-route": {
        "ClusterId": "review-cluster",
        "Match": { "Path": "/api/v1/products/{productId}/reviews/{**catch-all}" }
      },
      "coupons-route": {
        "ClusterId": "coupon-cluster",
        "Match": { "Path": "/api/v1/coupons/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/v1/ai/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/v1/users/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "support-route": {
        "ClusterId": "support-cluster",
        "Match": { "Path": "/api/v1/support/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "support-hub-route": {
        "ClusterId": "support-cluster",
        "Match": { "Path": "/hubs/support/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "auth": { "Address": "http://auth-service:8080" } }
      },
      "product-cluster": {
        "Destinations": { "product": { "Address": "http://product-service:8080" } }
      },
      "cart-cluster": {
        "Destinations": { "cart": { "Address": "http://cart-service:8080" } }
      },
      "order-cluster": {
        "Destinations": { "order": { "Address": "http://order-service:8080" } }
      },
      "payment-cluster": {
        "Destinations": { "payment": { "Address": "http://payment-service:8080" } }
      },
      "delivery-cluster": {
        "Destinations": { "delivery": { "Address": "http://delivery-service:8080" } }
      },
      "notification-cluster": {
        "Destinations": { "notification": { "Address": "http://notification-service:8080" } }
      },
      "review-cluster": {
        "Destinations": { "review": { "Address": "http://review-service:8080" } }
      },
      "coupon-cluster": {
        "Destinations": { "coupon": { "Address": "http://coupon-service:8080" } }
      },
      "ai-cluster": {
        "Destinations": { "ai": { "Address": "http://ai-service:8080" } }
      },
      "user-cluster": {
        "Destinations": { "user": { "Address": "http://user-service:8080" } }
      },
      "support-cluster": {
        "Destinations": { "support": { "Address": "http://support-service:8080" } }
      }
    }
  }
}

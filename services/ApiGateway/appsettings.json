{
  "Jwt": {
    "Secret": "your-super-secret-key-min-32-chars-long!!",
    "Issuer": "GroceryPlatform",
    "Audience": "GroceryPlatformClients"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1m", "Limit": 100 },
      { "Endpoint": "post:/api/v1/auth/login", "Period": "5m", "Limit": 10 }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "products-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/v1/products/{**catch-all}" }
      },
      "categories-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/v1/categories/{**catch-all}" }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/v1/cart/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/v1/orders/{**catch-all}" },
        "AuthorizationPolicy": "default"
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v1/payments/{**catch-all}" }
      },
      "deliveries-route": {
        "ClusterId": "delivery-cluster",
        "Match": { "Path": "/api/v1/deliveries/{**catch-all}" },
        "AuthorizationPolicy": "default"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "auth": { "Address": "http://auth-service:8080" } }
      },
      "product-cluster": {
        "Destinations": { "product": { "Address": "http://product-service:8080" } }
      },
      "cart-cluster": {
        "Destinations": { "cart": { "Address": "http://cart-service:8080" } }
      },
      "order-cluster": {
        "Destinations": { "order": { "Address": "http://order-service:8080" } }
      },
      "payment-cluster": {
        "Destinations": { "payment": { "Address": "http://payment-service:8080" } }
      },
      "delivery-cluster": {
        "Destinations": { "delivery": { "Address": "http://delivery-service:8080" } }
      }
    }
  }
}
